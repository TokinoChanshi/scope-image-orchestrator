{
  "schema_version": "scope-release-tests-v1",
  "notes": "Offline release gate inputs. These cases build request payloads, exercise response extraction, and run dry-run prompt routing without calling real APIs.",
  "adapter_payload_cases": [
    {
      "id": "openai-chat-json",
      "kind": "text",
      "adapter": "openai-chat",
      "base_url": "https://api.openai.com/v1",
      "model": "text-model",
      "expect_endpoint_contains": "/chat/completions",
      "expect_payload_keys": [
        "model",
        "messages",
        "response_format"
      ]
    },
    {
      "id": "openai-responses-json",
      "kind": "text",
      "adapter": "openai-responses",
      "base_url": "https://api.openai.com/v1",
      "model": "text-model",
      "expect_endpoint_contains": "/responses",
      "expect_payload_keys": [
        "model",
        "input"
      ]
    },
    {
      "id": "google-gemini-json",
      "kind": "text",
      "adapter": "google-gemini",
      "base_url": "https://generativelanguage.googleapis.com/v1beta",
      "model": "gemini-vision-model",
      "env": {
        "SCOPE_GOOGLE_API_KEY_AUTH": "header"
      },
      "expect_endpoint_contains": ":generateContent",
      "expect_payload_keys": [
        "contents",
        "systemInstruction",
        "generationConfig"
      ]
    },
    {
      "id": "openai-responses-vision",
      "kind": "vision",
      "adapter": "openai-responses",
      "base_url": "https://api.openai.com/v1",
      "model": "text-model",
      "expect_endpoint_contains": "/responses",
      "expect_payload_keys": [
        "model",
        "input"
      ]
    },
    {
      "id": "generic-vision-json",
      "kind": "vision",
      "adapter": "generic-vision-json",
      "base_url": "https://example.test/vision",
      "model": "custom-vision",
      "env": {
        "SCOPE_VISION_ENDPOINT_URL": "https://example.test/vision",
        "SCOPE_GENERIC_AUTH_MODE": "bearer"
      },
      "expect_endpoint_contains": "/vision",
      "expect_payload_keys": [
        "model",
        "prompt",
        "messages",
        "images",
        "image"
      ]
    },
    {
      "id": "openai-images",
      "kind": "image",
      "adapter": "openai-images",
      "base_url": "https://api.openai.com/v1",
      "model": "image-model",
      "env": {
        "SCOPE_IMAGE_SIZE": "1024x1536",
        "SCOPE_IMAGE_QUALITY": "high"
      },
      "expect_endpoint_contains": "/images/generations",
      "expect_payload_keys": [
        "model",
        "prompt",
        "size",
        "quality"
      ],
      "forbid_payload_keys": [
        "response_format"
      ]
    },
    {
      "id": "openai-responses-image",
      "kind": "image",
      "adapter": "openai-responses-image",
      "base_url": "https://api.openai.com/v1",
      "model": "text-model",
      "expect_endpoint_contains": "/responses",
      "expect_payload_keys": [
        "model",
        "input",
        "tools"
      ]
    },
    {
      "id": "google-gemini-image",
      "kind": "image",
      "adapter": "google-gemini-image",
      "base_url": "https://generativelanguage.googleapis.com/v1beta",
      "model": "gemini-vision-model-image",
      "env": {
        "SCOPE_GOOGLE_API_KEY_AUTH": "header"
      },
      "expect_endpoint_contains": ":generateContent",
      "expect_payload_keys": [
        "contents",
        "generationConfig"
      ]
    },
    {
      "id": "generic-image-json",
      "kind": "image",
      "adapter": "generic-image-json",
      "base_url": "https://example.test/image",
      "model": "custom-image",
      "env": {
        "SCOPE_IMAGE_ENDPOINT_URL": "https://example.test/image",
        "SCOPE_GENERIC_AUTH_MODE": "bearer",
        "SCOPE_IMAGE_RESPONSE_FORMAT": "b64_json"
      },
      "expect_endpoint_contains": "/image",
      "expect_payload_keys": [
        "model",
        "prompt",
        "n",
        "response_format"
      ]
    },
    {
      "id": "legacy-image-json",
      "kind": "image",
      "adapter": "openai-images-legacy",
      "base_url": "https://example.test/v1",
      "model": "image-model",
      "env": {
        "SCOPE_IMAGE_RESPONSE_FORMAT": "b64_json"
      },
      "expect_endpoint_contains": "/images/generations",
      "expect_payload_keys": [
        "model",
        "prompt",
        "n",
        "response_format"
      ]
    }
  ],
  "dry_run_prompts": [
    {
      "id": "portrait-basic",
      "route": "portrait",
      "prompt": "editorial portrait, half body, natural window light, realistic photography"
    },
    {
      "id": "lifestyle-interior",
      "route": "bathroom",
      "prompt": "indoor lifestyle portrait, mirror composition, warm practical light"
    },
    {
      "id": "poster-cinematic",
      "route": "poster",
      "prompt": "cinematic movie poster, night city atmosphere, high contrast lighting"
    },
    {
      "id": "product-packshot",
      "route": "product",
      "prompt": "commercial product packshot, clean background, soft realistic shadow"
    },
    {
      "id": "interior-living-room",
      "route": "interior",
      "prompt": "modern living room interior visualization, natural materials and hidden lighting"
    },
    {
      "id": "magazine-cover",
      "route": "magazine",
      "prompt": "high-end fashion magazine cover, refined layout, studio portrait"
    },
    {
      "id": "character-poster",
      "route": "cosplay",
      "prompt": "live-action character poster, fantasy costume, cinematic environment"
    },
    {
      "id": "documentary-candid",
      "route": "documentary",
      "prompt": "BBC documentary-style candid scene, off-center composition, cool neutral grading, real camera texture"
    },
    {
      "id": "strategy-overhead",
      "route": "strategy_overhead",
      "prompt": "top-down real-time strategy battlefield, readable unit clusters, no UI, premium game-render look"
    },
    {
      "id": "idiom-cinema-scene",
      "route": "idiom_cinema",
      "prompt": "low-saturation mythic Chinese cinematic tableau, black background, low-angle dramatic symbolism"
    },
    {
      "id": "anime-cel-character",
      "route": "anime_cel",
      "prompt": "clean cel-shaded anime character concept, full-body silhouette, restrained details, premium flat shading"
    },
    {
      "id": "mecha-tokusatsu-pack",
      "route": "cosplay",
      "prompt": "photoreal live-action mecha exosuit hero, storm-night industrial armor, visor mask, heavy metal wear, tactical under-suit"
    },
    {
      "id": "tactical-gear-packshot",
      "route": "product",
      "prompt": "commercial tactical vest and arm controller packshot, industrial lighting, premium engineered surfaces, restrained LED accents"
    },
    {
      "id": "turnaround-sheet-armor",
      "route": "cosplay",
      "prompt": "photoreal front side back turnaround sheet of a power armor character, neutral studio background, consistent proportions"
    },
    {
      "id": "cyber-jianghu-portrait",
      "route": "portrait",
      "prompt": "retro-futurist wuxia identity portrait, mechanical prosthetic detail, 35mm hong kong film mood, cold-warm contrast"
    },
    {
      "id": "industrial-monster-scene",
      "route": "documentary",
      "prompt": "fog-heavy offshore industrial platform scene with a full-body creature silhouette, hard-sci-fi realism, scale anchors, low visibility"
    },
    {
      "id": "commercial-identity-portrait",
      "route": "portrait",
      "prompt": "ultra-real commercial identity portrait, clean background, soft side light, visible pores, subtle blemishes, natural flyaway hair"
    }
  ],
  "response_extraction_cases": [
