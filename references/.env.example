# Open-source SCOPE Image Orchestrator example env.
# Copy to a task-local .env file and fill your own endpoint URLs and keys.
# Never commit real secrets.

# -------- Adapter selection --------
# Text / optimizer formats:
#   openai-chat        -> POST /v1/chat/completions
#   openai-responses   -> POST /v1/responses
#   google-gemini      -> POST /v1beta/models/{model}:generateContent
#   generic-text-json  -> POST a generic JSON body to SCOPE_LLM_ENDPOINT_URL
SCOPE_LLM_FORMAT=openai-responses

# Vision / verifier formats:
#   openai-chat
#   openai-responses
#   google-gemini
#   generic-vision-json
SCOPE_VISION_FORMAT=openai-responses

# Image formats:
#   openai-images          -> POST /v1/images/generations
#   openai-responses-image -> POST /v1/responses with image_generation tool
#   google-gemini-image    -> POST /v1beta/models/{model}:generateContent
#   openai-images-legacy   -> OpenAI-compatible JSON endpoints that still require response_format
#   generic-image-json     -> POST {"model","prompt","n",...} to SCOPE_IMAGE_ENDPOINT_URL
SCOPE_IMAGE_FORMAT=openai-images

# Google auth mode when using google-gemini / google-gemini-image:
#   header -> x-goog-api-key
#   query  -> ?key=...
#   bearer -> Authorization: Bearer ...
SCOPE_GOOGLE_API_KEY_AUTH=header

# -------- Text model --------
SCOPE_LLM_BASE_URL=https://api.openai.com/v1
SCOPE_LLM_API_KEY=your_key
SCOPE_LLM_MODEL=gpt-5.5

# -------- Optional separate vision model --------
SCOPE_VISION_BASE_URL=https://api.openai.com/v1
SCOPE_VISION_API_KEY=your_key
SCOPE_VISION_MODEL=gpt-5.5

# -------- Image model --------
SCOPE_IMAGE_BASE_URL=https://api.openai.com/v1
SCOPE_IMAGE_API_KEY=your_key
SCOPE_IMAGE_MODEL=gpt-image-2

# OpenAI Images API output controls. Omit fields you want the API to auto-select.
SCOPE_IMAGE_SIZE=1024x1536
SCOPE_IMAGE_QUALITY=high
# SCOPE_IMAGE_OUTPUT_FORMAT=png
# SCOPE_IMAGE_BACKGROUND=auto
# SCOPE_IMAGE_MODERATION=auto

# Retry controls.
SCOPE_CHAT_ATTEMPTS=4
SCOPE_VISION_ATTEMPTS=4
SCOPE_IMAGE_ATTEMPTS=4
SCOPE_IMAGE_RETRIES=1

# Legacy only: use this only with SCOPE_IMAGE_FORMAT=openai-images-legacy.
# SCOPE_RESPONSE_FORMATS=b64_json,url
# SCOPE_OPENAI_IMAGES_RESPONSE_FORMAT=b64_json

# -------- Previous / legacy OpenAI-compatible mode --------
# Use this when an endpoint follows the older JSON image format:
#   POST /v1/images/generations
#   {"model":"...","prompt":"...","n":1,"response_format":"b64_json|url"}
# SCOPE_LLM_FORMAT=openai-chat
# SCOPE_VISION_FORMAT=openai-chat
# SCOPE_IMAGE_FORMAT=openai-images-legacy
# SCOPE_IMAGE_BASE_URL=https://example.com/v1
# SCOPE_IMAGE_GENERATIONS_URL=https://example.com/v1/images/generations
# SCOPE_RESPONSE_FORMATS=b64_json,url,b64_json,url
# SCOPE_IMAGE_N=1
#
# Previous direct reference-image JSON fields are also supported in legacy mode
# when the endpoint documents them:
# SCOPE_SEND_REFERENCE_IMAGE=1
# SCOPE_REFERENCE_IMAGE_FIELD=images  # images|image|input_image|reference_image

# -------- Generic JSON adapters --------
# Use these when an endpoint is not official OpenAI/Gemini but accepts simple JSON.
# SCOPE_LLM_FORMAT=generic-text-json
# SCOPE_LLM_ENDPOINT_URL=https://example.com/text
# SCOPE_LLM_PAYLOAD_STYLE=both   # both|messages|prompt
#
# SCOPE_VISION_FORMAT=generic-vision-json
# SCOPE_VISION_ENDPOINT_URL=https://example.com/vision
# SCOPE_VISION_PAYLOAD_STYLE=both
#
# SCOPE_IMAGE_FORMAT=generic-image-json
# SCOPE_IMAGE_ENDPOINT_URL=https://example.com/image
# SCOPE_IMAGE_RESPONSE_FORMAT=b64_json
#
# Generic auth:
# SCOPE_GENERIC_AUTH_MODE=bearer # bearer|api-key|header|header:X-Custom-Key|query|none
# SCOPE_GENERIC_AUTH_HEADER=X-API-Key
# SCOPE_GENERIC_API_KEY_QUERY_PARAM=key

# Reference images:
# - Default: reference image -> vision brief -> prompt injection.
# - Direct official reference input is supported by openai-responses-image and google-gemini-image.
# - OpenAI Images API reference editing uses /v1/images/edits multipart and is documented separately.
